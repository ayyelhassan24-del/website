{
  "buildCommand": "exit 0",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!uploads/|.*\\.\\w+$).*)",
      "destination": "/index.html"
    }
  ]
}
